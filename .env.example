# ─────────────────────────────────────────────────────────────────────────────
# AI Trading Terminal — environment configuration
# Copy this file to `.env` (same directory) and fill in your own values.
# `.env` is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Alpaca (REQUIRED) ────────────────────────────────────────────────────────
# Free paper account + keys: https://app.alpaca.markets  (Paper Trading → API Keys)
# The secret is shown only once — copy it immediately.
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_API_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_PAPER_TRADE=true
# Options data feed: 'indicative' (free) or 'opra' (real-time, paid entitlement)
ALPACA_OPTIONS_FEED=indicative

# Going LIVE (only after a long paper track record — real money at risk):
# ALPACA_API_BASE_URL=https://api.alpaca.markets/v2
# ALPACA_PAPER_TRADE=false

# ── AI research / chat providers ─────────────────────────────────────────────
# Research uses a cloud LLM primary with a free local fallback; chat uses local.
#   research primary  = kimi  (Moonshot, paid) — runs ONLY on explicit Analyze/Deep-dive
#   research backup   = ollama (local Gemma, free) — also the 24/7 background worker
#   chat provider     = ollama (local Gemma, free) — the Vanna text-to-SQL chat
RESEARCH_PROVIDER=kimi
RESEARCH_BACKUP_PROVIDER=ollama
CHAT_PROVIDER=ollama

# Moonshot Kimi (OpenAI-compatible). Get a key at https://platform.kimi.ai
# NOTE: kimi-k2.x are reasoning models and require temperature=1 (handled in code).
# Leave KIMI_API_KEY blank to run research fully on local Gemma (free) instead.
KIMI_API_KEY=your_kimi_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.5

# Local Gemma via Ollama (free; powers the 24/7 worker + chat).
# Install Ollama (https://ollama.com), then: `ollama pull gemma4:e2b`
OLLAMA_BASE_URL=http://localhost:11434
RESEARCH_MODEL=gemma4:e2b

# Optional alternate research provider (only used if RESEARCH_PROVIDER=anthropic):
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Database ─────────────────────────────────────────────────────────────────
# The WEB build uses MySQL (e.g. MAMP defaults below: host 127.0.0.1, port 8889,
# user/pass root/root). The NATIVE macOS app uses embedded SQLite automatically
# (DB_BACKEND/SQLITE_PATH are set by the app — you don't set them here).
DB_BACKEND=mysql
DB_HOST=127.0.0.1
DB_PORT=8889
DB_USER=root
DB_PASSWORD=root
DB_NAME=trading_terminal
DATABASE_URL=mysql://root:root@127.0.0.1:8889/trading_terminal
