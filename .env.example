# Copy to .env and fill in. Get keys from https://app.alpaca.markets (Paper Trading → API Keys).
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_API_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_PAPER_TRADE=true

# Live trading (DO NOT FILL until the live gate — ≥30 paper days first):
# ALPACA_API_BASE_URL=https://api.alpaca.markets/v2
# ALPACA_PAPER_TRADE=false

# Anthropic API for the AI Analyst:
ANTHROPIC_API_KEY=your_anthropic_key_here
