{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Trading Terminal",
  "version": "1.0.0",
  "identifier": "com.orcounselors.tradingterminal",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
